# Location of BUFG Primitives 
set_property LOC BUFGCTRL_X0Y3 [get_cells video_clock_BUFG_inst]
set_property LOC BUFGCTRL_X0Y1 [get_cells v_sync_signal_OBUF_BUFG_inst]
set_property LOC BUFGCTRL_X0Y4 [get_cells graphics_row_reg[1016]_i_3]
set_property LOC BUFGCTRL_X0Y6 [get_cells ov7670_pclk_IBUF_BUFG_inst]
set_property LOC BUFGCTRL_X0Y2 [get_cells h_sync_signal_OBUF_BUFG_inst]
set_property LOC BUFGCTRL_X0Y5 [get_cells camera_data_even_line_i_1]
set_property LOC BUFGCTRL_X0Y19 [get_cells camera_video/xtime/inst/clkf_buf]
set_property LOC BUFGCTRL_X0Y18 [get_cells camera_video/xtime/inst/clkout2_buf]
set_property LOC BUFGCTRL_X0Y17 [get_cells camera_video/xtime/inst/clkout3_buf]
set_property LOC BUFGCTRL_X0Y16 [get_cells camera_video/xtime/inst/clkout1_buf]
set_property LOC BUFGCTRL_X0Y0 [get_cells camera_video/Inst_DDR/u_ddr_mig/u_ddr2_infrastructure/u_bufg_clkdiv0]
set_property LOC BUFGCTRL_X0Y7 [get_cells sreg_reg[15]_i_3]

# Location of BUFH Primitives 
set_property LOC BUFHCE_X1Y12 [get_cells camera_video/Inst_DDR/u_ddr_mig/u_ddr2_infrastructure/u_bufh_pll_clk3]

# Location of IO Primitives which is load of clock spine
set_property LOC IOB_X0Y143 [get_cells v_sync_signal_OBUF_inst]
set_property LOC IOB_X0Y142 [get_cells h_sync_signal_OBUF_inst]

# Location of clock ports
set_property LOC IOB_X1Y126 [get_ports clock]
set_property LOC IOB_X1Y110 [get_ports ov7670_pclk]

# Clock net "video_clock_BUFG" driven by instance "video_clock_BUFG_inst" located at site "BUFGCTRL_X0Y3"
#startgroup
create_pblock {CLKAG_video_clock_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_video_clock_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="video_clock_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_video_clock_BUFG}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0 CLOCKREGION_X1Y0:CLOCKREGION_X1Y0 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1}
#endgroup

# Clock net "v_sync_signal_OBUF_BUFG" driven by instance "v_sync_signal_OBUF_BUFG_inst" located at site "BUFGCTRL_X0Y1"
#startgroup
create_pblock {CLKAG_v_sync_signal_OBUF_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_v_sync_signal_OBUF_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL && NAME!=v_sync_signal_OBUF_inst} -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="v_sync_signal_OBUF_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_v_sync_signal_OBUF_BUFG}] -add {CLOCKREGION_X1Y0:CLOCKREGION_X1Y0 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1}
#endgroup

# Clock net "system_clock" driven by instance "graphics_row_reg[1016]_i_3" located at site "BUFGCTRL_X0Y4"
#startgroup
create_pblock {CLKAG_system_clock}
add_cells_to_pblock [get_pblocks  {CLKAG_system_clock}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="system_clock"}]]]
resize_pblock [get_pblocks {CLKAG_system_clock}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0 CLOCKREGION_X0Y1:CLOCKREGION_X0Y1 CLOCKREGION_X0Y2:CLOCKREGION_X0Y2 CLOCKREGION_X1Y0:CLOCKREGION_X1Y0 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1}
#endgroup

